---
import productsData from '../data/products.json';
import 'glightbox/dist/css/glightbox.min.css';

let products = productsData;
---
<section class="gallery">
  <a href="https://www.printify.com/shop/jurassinkart" class="shop-link" target="_blank" rel="noopener">Visit the Shop</a>
  <h2>Featured Works</h2>
  <div class="gallery-grid">
    {products.length > 0 ? (
      products.map(product => (
        <div class="gallery-card">
          {product.image ? (
            <a href={product.image} class="glightbox" data-title={product.title} data-description="Dinosaurs & Prehistoric Art">
              <img src={product.image} alt={product.title} loading="lazy" />
            </a>
          ) : (
            <div class="no-image">No Image</div>
          )}
        </div>
      ))
    ) : (
      <p class="empty-state">Curating featured posters and canvas works — check back soon.</p>
    )}
  </div>
  <a href="https://www.printify.com/shop/jurassinkart" class="shop-link" target="_blank" rel="noopener">Visit the Shop</a>
</section>

<style>
  .gallery {
    padding: 2rem 0;
  }
  
  .gallery h2 {
    text-align: center;
    margin-bottom: 2.5rem;
  }
  
  /* COLUMNS / RESPONSIVE (Classy Masonry Layout) */
  .gallery-grid {
    column-count: 1;
    column-gap: 2rem;
    padding: 0 1rem;
    max-width: 1200px;
    margin: 0 auto;
  }
  
  @media (min-width: 600px) {
    .gallery-grid { column-count: 2; }
  }
  @media (min-width: 900px) {
    .gallery-grid { column-count: 3; }
  }
  @media (min-width: 1200px) {
    .gallery-grid { column-count: 4; }
  }

  /* NORMALIZE CARD SIZE & HOVER EFFECT */
  .gallery-card {
    break-inside: avoid;
    margin-bottom: 2rem;
    position: relative;
    border-radius: 16px;
    overflow: hidden;
    background: rgba(0, 0, 0, 0.2);
    cursor: pointer;
    /* Base styles for scroll animation */
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1), transform 0.8s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.3s ease;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
  }
  
  .gallery-card.visible {
    opacity: 1;
    transform: translateY(0) scale(1); /* Return to original state */
  }

  /* FIX IMAGE BEHAVIOR */
  .gallery-card img {
    width: 100%;
    height: auto;
    display: block;
    transform: scale(1);
    transition: transform 0.6s cubic-bezier(0.175, 0.885, 0.32, 1.275), filter 0.6s ease;
    filter: saturate(1.05) contrast(1.05);
  }
  
  .gallery-card:hover img {
    /* Classy subtle zoom in border bounds */
    transform: scale(1.03); 
    filter: saturate(1.1) contrast(1.1) brightness(1.1);
  }

  .no-image {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #333;
    color: #999;
  }

  .empty-state {
    grid-column: 1 / -1;
    text-align: center;
    color: #d4c9b6;
    font-size: 1rem;
    letter-spacing: 0.02em;
    padding: 2rem 1rem;
  }

</style>
