---
import { GET } from '../pages/api/printify.js';

let products = [];
try {
  // Call the endpoint function directly so we don't have networking/port issues
  const response = await GET();
  if (response.ok) {
    products = await response.json();
  }
} catch (e) {
  console.error('Failed to load products from API route', e);
}
---
<section class="gallery">
  <h2>Featured Works</h2>
  <div class="gallery-grid">
    {products.length > 0 ? (
      products.map(product => (
        <div class="gallery-card" data-tilt data-tilt-max="15" data-tilt-speed="400" data-tilt-perspective="1000" data-tilt-glare="true" data-tilt-max-glare="0.3">
          {product.image ? (
            <img src={product.image} alt={product.title} loading="lazy" />
          ) : (
            <div class="no-image">No Image</div>
          )}
        </div>
      ))
    ) : (
      <p class="empty-state">Curating featured posters and canvas works — check back soon.</p>
    )}
  </div>
</section>

<style>
  .gallery {
    padding: 2rem 0;
  }
  
  .gallery h2 {
    text-align: center;
    margin-bottom: 2.5rem;
  }
  
  /* GRID / RESPONSIVE (Task 6) */
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(1, 1fr);
    gap: 2rem;
    padding: 0 1rem;
    max-width: 1200px;
    margin: 0 auto;
  }
  
  @media (min-width: 600px) {
    .gallery-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 900px) {
    .gallery-grid { grid-template-columns: repeat(3, 1fr); }
  }
  @media (min-width: 1200px) {
    .gallery-grid { grid-template-columns: repeat(4, 1fr); }
  }

  /* NORMALIZE CARD SIZE & HOVER EFFECT (Tasks 3 & 5) */
  .gallery-card {
    position: relative;
    aspect-ratio: 1 / 1;
    border-radius: 22px;
    overflow: hidden;
    background: transparent;
    cursor: pointer;
    /* Base styles for scroll animation */
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1), transform 0.8s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.3s ease;
    /* Removed the feathered mask to make it a solid thumbnail block */
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
  }
  
  .gallery-card.visible {
    opacity: 1;
    transform: translateY(0) scale(1); /* Return to original state */
  }

  /* FIX IMAGE BEHAVIOR (Task 2) */
  .gallery-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    /* Zoom in significantly to crop out the white frames/walls from mockups */
    transform: scale(1.65);
    transition: transform 0.6s cubic-bezier(0.175, 0.885, 0.32, 1.275), filter 0.6s ease;
    filter: saturate(1.1) contrast(1.1);
  }
  
  .gallery-card:hover img {
    /* Fun zoom out/in pop effect */
    transform: scale(1.75); 
    filter: saturate(1.2) contrast(1.15) brightness(1.1);
  }

  .no-image {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #333;
    color: #999;
  }

  .empty-state {
    grid-column: 1 / -1;
    text-align: center;
    color: #d4c9b6;
    font-size: 1rem;
    letter-spacing: 0.02em;
    padding: 2rem 1rem;
  }

</style>

<script>
  import VanillaTilt from 'vanilla-tilt';

  // Wait for the DOM to be fully loaded
  document.addEventListener('DOMContentLoaded', () => {
    // Initialize Vanilla Tilt on the cards
    VanillaTilt.init(document.querySelectorAll('.gallery-card'), {
      max: 12,
      speed: 400,
      glare: true,
      "max-glare": 0.4,
      scale: 1.05
    });

    // Observer options
    const observerOptions = {
      root: null,
      rootMargin: '0px 0px -10% 0px', // Trigger when 10% from the bottom of the viewport
      threshold: 0.1 // Trigger when 10% of the element is visible
    };

    // The observer callback function
    const observerCallback = (entries: IntersectionObserverEntry[], observer: IntersectionObserver) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          // Add the visible class to trigger the CSS transition
          entry.target.classList.add('visible');
          // Stop observing once it's visible so it doesn't animate out and back in
          observer.unobserve(entry.target);
        }
      });
    };

    // Create the Intersection Observer
    const observer = new IntersectionObserver(observerCallback, observerOptions);

    // Find all gallery cards and start observing them
    const cards = document.querySelectorAll('.gallery-card');
    cards.forEach((card, index) => {
      // Add a slight staggered delay based on 3-column grid position so rows don't just appear simultaneously
      (card as HTMLElement).style.transitionDelay = `${(index % 3) * 0.1}s`;
      observer.observe(card);
    });
  });
</script>
