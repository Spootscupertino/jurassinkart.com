---
import Hero from '../components/Hero.astro';
import Gallery from '../components/Gallery.astro';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Jurassinkart — Prehistoric Art That Feels Alive</title>
  <meta name="description" content="Cinematic dinosaur artwork inspired by ancient jungles, deep oceans, and primeval skies. Shop prints at Jurassinkart." />
  
  <style is:global>
    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Georgia', 'Times New Roman', serif;
      background: linear-gradient(
        to bottom,
        rgba(9, 14, 23, 0.85) 0%,
        rgba(3, 8, 12, 0.95) 100%
      ), url('/assets/prehistoric-tree.png') center/cover fixed;
      color: #e8e0d4;
      overflow-x: hidden;
    }

    /* ── Hero ─────────────────────────────────── */
    .hero {
      position: relative;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
    }
    .hero video {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      opacity: 0.45;
    }
    .hero-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(
        to bottom,
        rgba(9,14,23,0.3) 0%,
        rgba(9,14,23,0.6) 60%,
        #090e17 100%
      );
    }
    .hero-content {
      position: relative;
      z-index: 2;
      text-align: center;
      padding: 0 24px;
      max-width: 780px;
    }
    .hero-content h1 {
      font-size: clamp(2.4rem, 6vw, 4.2rem);
      line-height: 1.15;
      letter-spacing: -0.02em;
      color: #f5f0e8;
      margin-bottom: 20px;
    }
    .hero-content p {
      font-size: 1.15rem;
      line-height: 1.7;
      color: #bfb8aa;
      max-width: 600px;
      margin: 0 auto 36px;
    }

    /* ── Buttons ──────────────────────────────── */
    .btn {
      display: inline-block;
      padding: 15px 32px;
      background: #c2652a;
      color: #fff;
      text-decoration: none;
      border-radius: 6px;
      font-family: Arial, Helvetica, sans-serif;
      font-size: 0.95rem;
      font-weight: 700;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      transition: background 0.25s;
    }
    .btn:hover { background: #a8531e; }

    /* ── Gallery ──────────────────────────────── */
    .gallery {
      max-width: 1100px;
      margin: 0 auto;
      padding: 80px 24px;
    }
    .gallery h2 {
      text-align: center;
      font-size: 2rem;
      margin-bottom: 48px;
      color: #d4c9b6;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      font-weight: 400;
    }
    .gallery-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 28px;
    }
    .gallery-item {
      position: relative;
      border-radius: 20px;
      overflow: hidden;
      background: transparent;
      /* Smoothly feather the edges so the white wall mockups vanish into the dark jungle */
      -webkit-mask-image: radial-gradient(ellipse at center, rgba(0,0,0,1) 50%, rgba(0,0,0,0) 100%);
      mask-image: radial-gradient(ellipse at center, rgba(0,0,0,1) 50%, rgba(0,0,0,0) 100%);
    }
    .gallery-item img {
      width: 100%;
      height: 480px; /* Make it taller to crop further into the sweet spot */
      object-fit: cover;
      object-position: center 20%; /* Push up slightly to cut off top white space if possible */
      display: block;
      transition: transform 0.8s ease, filter 0.8s ease;
    }
    .gallery-item:hover img {
      transform: scale(1.08); /* Stronger scale for the flow effect */
      filter: brightness(1.2) contrast(1.1);
    }
    .gallery-caption {
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      padding: 40px 20px 20px;
      background: transparent;
      text-align: center;
      pointer-events: none;
    }
    .gallery-caption h3 {
      font-size: 1.3rem;
      margin-bottom: 6px;
      color: #fff;
      text-shadow: 0 2px 12px rgba(0,0,0,0.8);
    }
    .gallery-caption p {
      font-size: 0.95rem;
      color: #dfd8cb;
      line-height: 1.5;
      margin: 0;
      text-shadow: 0 1px 8px rgba(0,0,0,0.8);
    }

    /* ── World section ────────────────────────── */
    .world {
      max-width: 780px;
      margin: 0 auto;
      padding: 60px 24px 100px;
      text-align: center;
    }
    .world h2 {
      font-size: 2rem;
      margin-bottom: 20px;
      color: #d4c9b6;
    }
    .world p {
      font-size: 1.1rem;
      line-height: 1.75;
      color: #9e978a;
      margin-bottom: 36px;
    }

    /* ── Divider ──────────────────────────────── */
    .divider {
      width: 60px;
      height: 1px;
      background: #3a3225;
      margin: 0 auto 60px;
    }

    /* ── Footer ───────────────────────────────── */
    footer {
      text-align: center;
      padding: 40px 24px;
      border-top: 1px solid #1a1e28;
      font-family: Arial, Helvetica, sans-serif;
      font-size: 0.8rem;
      color: #4a4539;
      position: relative;
      z-index: 10;
    }
    footer a { color: #7a6f5e; text-decoration: none; }
    footer a:hover { color: #c2652a; }

    /* ── Mobile ───────────────────────────────── */
    @media (max-width: 680px) {
      .gallery-grid { grid-template-columns: 1fr; }
      .gallery-item img { height: 420px; }
    }

    /* ── Lenis Smooth Scrolling ──────────────── */
    html.lenis, html.lenis body {
      height: auto;
    }
    .lenis.lenis-smooth {
      scroll-behavior: auto !important;
    }
    .lenis.lenis-smooth [data-lenis-prevent] {
      overscroll-behavior: contain;
    }
    .lenis.lenis-stopped {
      overflow: hidden;
    }
    .lenis.lenis-smooth iframe {
      pointer-events: none;
    }

    /* ── Ambient Dust ────────────────────────── */
    #ambient-dust {
      position: fixed;
      top: 0;
      left: 0;
      width: 100vw;
      height: 100vh;
      pointer-events: none; /* Crucial: lets you click through it */
      z-index: 999;
      opacity: 0.5;
    }

    /* ── Custom Cursor & Hover States ────────── */
    @media (pointer: fine) {
      body {
        cursor: none;
      }
      a, button, .btn {
        cursor: none;
      }
    }
    #custom-cursor {
      position: fixed;
      top: 0;
      left: 0;
      width: 12px;
      height: 12px;
      border-radius: 50%;
      background: #f5f0e8;
      pointer-events: none;
      z-index: 99999;
      transform: translate(-50%, -50%);
      transition: width 0.3s cubic-bezier(0.25, 1, 0.5, 1), 
                  height 0.3s cubic-bezier(0.25, 1, 0.5, 1), 
                  background 0.3s ease, 
                  opacity 0.3s ease;
      mix-blend-mode: difference;
    }
    #custom-cursor.hovering {
      width: 50px;
      height: 50px;
      background: rgba(245, 235, 220, 0.4);
      mix-blend-mode: normal;
      backdrop-filter: blur(2px);
    }
    #custom-cursor.magnetic {
      width: 8px;
      height: 8px;
      background: #fff;
    }
  </style>
</head>
<body>

  <div id="custom-cursor"></div>
  <canvas id="ambient-dust"></canvas>

  <!-- ── Hero with looping video ── -->
  <Hero />

  <!-- ── Gallery ── -->
  <Gallery />

  <!-- ── World ── -->
  <section class="world">
    <div class="divider"></div>
    <h2>The World of Jurassinkart</h2>
    <p>
      Ancient forests. Sunlit canopies. Deep water. Towering creatures.
      Jurassinkart is built around the feeling of stepping into a lost world —
      one that is dramatic, immersive, and exciting for dinosaur fans of all ages.
    </p>
    <a class="btn" href="https://www.etsy.com/shop/Jurassinkart" target="_blank" rel="noopener">Shop the Collection</a>
  </section>

  <footer>
    &copy; 2026 Jurassinkart &nbsp;·&nbsp;
    <a href="https://www.etsy.com/shop/Jurassinkart" target="_blank" rel="noopener">Etsy</a>
  </footer>

  <!-- ── Smooth Scrolling (Lenis) ── -->
  <script src="https://unpkg.com/@studio-freight/lenis@1.0.42/dist/lenis.min.js"></script>
  <script is:inline>
    const lenis = new Lenis({
      duration: 1.6, /* Makes it drift very smoothly */
      easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)), /* Ease-out curve */
      smooth: true
    });

    function raf(time) {
      lenis.raf(time);
      requestAnimationFrame(raf);
    }
    requestAnimationFrame(raf);
  </script>

  <!-- ── Ambient Dust Script ── -->
  <script is:inline>
    (function initDust() {
      const canvas = document.getElementById('ambient-dust');
      const ctx = canvas.getContext('2d');
      let width, height;
      let particles = [];

      function resize() {
        width = canvas.width = window.innerWidth;
        height = canvas.height = window.innerHeight;
        // Re-generate particles if screen wildly changes, otherwise just adjust bounds
        particles = [];
        const count = Math.floor(window.innerWidth / 7); // Responsive amount of dust
        for (let i = 0; i < count; i++) {
          particles.push({
            x: Math.random() * width,
            y: Math.random() * height,
            r: Math.random() * 1.5 + 0.5,
            vx: (Math.random() - 0.5) * 0.2, // Drift left/right
            vy: -1 * Math.random() * 0.4 - 0.1, // Float upward slowly
            baseAlpha: Math.random() * 0.5 + 0.1,
            pulse: Math.random() * Math.PI * 2 // Give each a random phase for pulsing light
          });
        }
      }

      window.addEventListener('resize', resize);
      resize();

      function animate() {
        ctx.clearRect(0, 0, width, height);

        particles.forEach(p => {
          // Update positions
          p.x += p.vx;
          p.y += p.vy;
          
          // Gently pulse the opacity to simulate passing through light rays
          p.pulse += 0.02;
          const currentAlpha = p.baseAlpha + Math.sin(p.pulse) * 0.1;

          // Wrap around edges
          if (p.x < -10) p.x = width + 10;
          if (p.x > width + 10) p.x = -10;
          if (p.y < -10) p.y = height + 10;

          // Draw the dusty speck
          ctx.beginPath();
          ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
          // Faint golden/white dirt
          ctx.fillStyle = `rgba(245, 235, 220, ${Math.max(0, currentAlpha)})`;
          ctx.fill();
        });

        requestAnimationFrame(animate);
      }
      
      requestAnimationFrame(animate);
    })();
  </script>

  <!-- ── Interactive Cursor, Parallax, and Magnetic Buttons ── -->
  <script is:inline>
    (function initInteractive() {
      // 1. Custom Cursor
      const cursor = document.getElementById('custom-cursor');
      if (window.matchMedia("(pointer: fine)").matches) {
        let mouseX = 0, mouseY = 0;
        let cursorX = 0, cursorY = 0;
        
        window.addEventListener('mousemove', (e) => {
          mouseX = e.clientX;
          mouseY = e.clientY;
        });

        // Smooth follower
        function smoothCursor() {
          const dx = mouseX - cursorX;
          const dy = mouseY - cursorY;
          cursorX += dx * 0.2; // The lower the value, the smoother/slower the trail
          cursorY += dy * 0.2;
          cursor.style.transform = `translate3d(${cursorX}px, ${cursorY}px, 0) translate(-50%, -50%)`;
          requestAnimationFrame(smoothCursor);
        }
        requestAnimationFrame(smoothCursor);

        // Hover states
        const hoverElements = document.querySelectorAll('.gallery-card, .gallery-item, a:not(.btn)');
        hoverElements.forEach(el => {
          el.addEventListener('mouseenter', () => cursor.classList.add('hovering'));
          el.addEventListener('mouseleave', () => cursor.classList.remove('hovering'));
        });
      }

      // 2. Parallax Background
      const parallaxBg = document.querySelector('.parallax-layer');
      const parallaxContent = document.querySelector('.parallax-content');
      
      function updateParallax() {
        const scrollY = window.scrollY;
        if (parallaxBg) {
          // Move background slower than the scroll
          parallaxBg.style.transform = `translate3d(0, ${scrollY * 0.4}px, 0)`;
        }
        if (parallaxContent) {
          // Push text up slightly faster and fade out
          parallaxContent.style.transform = `translate3d(0, ${scrollY * 0.2}px, 0)`;
          parallaxContent.style.opacity = 1 - (scrollY / 600);
        }
      }
      
      // Hook into Lenis via native scroll (Lenis drives native scroll)
      window.addEventListener('scroll', updateParallax);
      updateParallax();

      // 3. Magnetic Buttons
      const magneticBtns = document.querySelectorAll('.btn, .magnetic-btn');
      magneticBtns.forEach(btn => {
        btn.addEventListener('mousemove', (e) => {
          const rect = btn.getBoundingClientRect();
          // Calculate center of button
          const hX = rect.left + rect.width / 2;
          const hY = rect.top + rect.height / 2;
          
          // Distance from mouse to center
          const dX = e.clientX - hX;
          const dY = e.clientY - hY;
          
          // Pull effect
          btn.style.transform = `translate(${dX * 0.3}px, ${dY * 0.3}px)`;
          if (cursor) cursor.classList.add('magnetic');
        });
        
        btn.addEventListener('mouseleave', () => {
          btn.style.transform = '';
          if (cursor) cursor.classList.remove('magnetic');
        });
      });
    })();
  </script>

</body>
</html>
